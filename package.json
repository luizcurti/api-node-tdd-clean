{
  "name": "api-node-tdd-clean",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "license": "ISC",
  "main": "src/main/index.js",
  "scripts": {
    "start": "node src/main/index.js",
    "dev": "nodemon src/main/index.js",
    "test": "jest --colors --noStackTrace --passWithNoTests --runInBand",
    "test:unit": "npm test -- --testMatch='**/*.spec.js'",
    "test:unit:watch": "npm test -- --watch --testMatch='**/*.spec.js'",
    "test:unit:coverage": "npm test -- --coverage --testMatch='**/*.spec.js'",
    "test:integration": "npm test -- --testMatch='**/*.test.js'",
    "test:integration:watch": "npm test -- --watch --testMatch='**/*.test.js'",
    "test:integration:coverage": "npm test -- --coverage --testMatch='**/*.test.js'",
    "test:coverage": "npm test -- --coverage",
    "test:coverage:open": "npm run test:coverage && open coverage/index.html",
    "test:ci": "npm test -- --coverage --silent",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand --colors --noStackTrace",
    "test:e2e:watch": "jest --config jest.e2e.config.js --runInBand --watch",
    "test:e2e:coverage": "jest --config jest.e2e.config.js --runInBand --coverage",
    "test:e2e:docker": "docker compose up mongodb -d && sleep 5 && npm run test:e2e",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "lint:check": "eslint src --ext .js --max-warnings 0",
    "docker:db": "docker compose up mongodb mongo-express -d",
    "docker:db:stop": "docker compose down",
    "docker:db:logs": "docker compose logs -f mongodb",
    "docker:full": "docker compose --profile full-stack up -d",
    "docker:reset": "docker compose down -v && docker compose up mongodb mongo-express -d",
    "db:setup": "node scripts/setup-database.js",
    "db:setup:seed": "node scripts/setup-database.js --seed",
    "db:reset": "node scripts/reset-database.js",
    "db:reset:setup": "node scripts/reset-database.js --setup"

  },
  "standard": {
    "env": [
      "jest"
    ]
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "standard": "^17.1.0",
    "supertest": "^7.1.3"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^4.19.2",
    "fast-glob": "^3.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "validator": "^13.15.15"
  }
}
