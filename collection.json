{
  "info": {
    "name": "API Node TDD Clean",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5858/api" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"OK\",\n  \"timestamp\": \"2026-03-24T00:00:00.000Z\",\n  \"uptime\": 10.5,\n  \"environment\": \"development\",\n  \"version\": \"1.0.0\"\n}"
            }
          ]
        }
      ]
    },
    {
